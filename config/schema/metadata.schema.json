{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ee-wiki.local/schema/metadata.json",
  "title": "EE-Wiki Document Metadata",
  "type": "object",
  "required": ["project", "build", "document_type", "title", "source_file"],
  "properties": {
    "project": { "type": "string" },
    "build": { "type": "string" },
    "document_type": { "type": "string" },
    "page": { "type": "integer", "minimum": 0 },
    "title": { "type": "string", "minLength": 1 },
    "source_file": { "type": "string", "minLength": 1 },
    "target_file": { "type": "string", "minLength": 1 },
    "source_mtime": { "type": "number" },
    "source_size": { "type": "integer", "minimum": 0 },
    "major_components": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Schematic documents only (sch/)"
    },
    "nets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Schematic documents only (sch/)"
    },
    "interfaces": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Schematic (sch/) module/interface names; datasheet protocol names (I2C, SPI, …)"
    },
    "supply_voltage": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Datasheet documents only — supply voltage rails or ranges (e.g. 3.3V, 2.0V-3.6V)"
    },
    "pin_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Datasheet documents only — package pin count when detected"
    },
    "package": {
      "type": "string",
      "description": "Datasheet documents only — primary package designator (e.g. LQFP144, QFN-48)"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pages": {
      "type": "array",
      "description": "Schematic documents only (sch/) — per-page metadata for chunk indexing",
      "items": {
        "type": "object",
        "required": ["page"],
        "properties": {
          "page": { "type": "integer", "minimum": 1 },
          "major_components": {
            "type": "array",
            "items": { "type": "string" }
          },
          "nets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "interfaces": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "version": { "type": "string" }
  },
  "additionalProperties": true
}
