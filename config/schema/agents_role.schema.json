{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ee-wiki.local/schema/agents_role.schema.json",
  "title": "EE-Wiki agent role pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "display_name", "routing", "tools", "recipe"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,31}$"
    },
    "display_name": { "type": "string", "minLength": 1 },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keywords"],
      "properties": {
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "recipe": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool"],
        "properties": {
          "tool": { "type": "string", "minLength": 1 },
          "args": {
            "type": "object",
            "additionalProperties": true
          },
          "query_from": {
            "type": "string",
            "enum": ["question", "tokens"]
          }
        }
      }
    },
    "max_tool_calls": {
      "type": "integer",
      "minimum": 1,
      "maximum": 32
    }
  }
}
