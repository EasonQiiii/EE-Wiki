{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ee-wiki.local/schema/qa_eval.json",
  "title": "EE-Wiki RAG Evaluation Dataset",
  "type": "object",
  "required": ["version", "corpus", "scoring", "cases"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "corpus": {
      "type": "object",
      "required": ["manifest", "chunk_count", "built_at", "coverage"],
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "chunk_count": { "type": "integer", "minimum": 0 },
        "built_at": { "type": "string", "minLength": 1 },
        "coverage": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "scoring": {
      "type": "object",
      "required": ["dimensions", "pass_thresholds"],
      "properties": {
        "dimensions": {
          "type": "object",
          "required": ["retrieval", "answer_accuracy", "citation_scope", "stability"],
          "additionalProperties": {
            "type": "object",
            "required": ["weight", "max_score"],
            "properties": {
              "weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "max_score": { "type": "integer", "minimum": 1 },
              "description": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "pass_thresholds": {
          "type": "object",
          "required": ["mandatory_accuracy", "weighted_mean", "negative_refusal_rate"],
          "properties": {
            "mandatory_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
            "weighted_mean": { "type": "number", "minimum": 0 },
            "negative_refusal_rate": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "datasheet",
        "schematic",
        "sop",
        "fa",
        "scope",
        "platform",
        "negative",
        "stability"
      ]
    },
    "filters": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["product", "project", "build"],
          "properties": {
            "product": { "type": "string", "minLength": 1 },
            "project": { "type": "string", "minLength": 1 },
            "build": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "case": {
      "type": "object",
      "required": [
        "id",
        "title",
        "category",
        "mandatory",
        "filters",
        "scope_label",
        "question",
        "expected_answer",
        "required_sources"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^Q-\\d{3}$"
        },
        "title": { "type": "string", "minLength": 1 },
        "category": { "$ref": "#/$defs/category" },
        "mandatory": { "type": "boolean" },
        "filters": { "$ref": "#/$defs/filters" },
        "scope_label": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "enum": ["build", "common", "product_common", "global"]
            }
          ]
        },
        "expect_refusal": { "type": "boolean" },
        "question": { "type": "string", "minLength": 1 },
        "paraphrases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "expected_answer": { "type": "string", "minLength": 1 },
        "expected_facts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "optional_sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "must_not_contain": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_scope": { "$ref": "#/$defs/filters" },
        "forbidden_sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "category": { "const": "negative" } },
            "required": ["category"]
          },
          "then": {
            "required": ["expect_refusal"],
            "properties": { "expect_refusal": { "const": true } }
          }
        },
        {
          "if": {
            "properties": { "category": { "const": "stability" } },
            "required": ["category"]
          },
          "then": {
            "required": ["paraphrases"],
            "properties": {
              "paraphrases": { "type": "array", "minItems": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
