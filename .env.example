# Copy and export these variables in your shell (or use direnv).
# The repository does not auto-load .env — you must export manually.

# Paths (relative to repo root or absolute)
EE_WIKI_DATA_DIR=./data
EE_WIKI_MODELS_DIR=/path/to/models

# Optional: Tesseract language data for prose PDF OCR (when auto-detect fails)
# EE_WIKI_TESSDATA_DIR=/opt/homebrew/share/tessdata

# Optional: force embedding device for scripts/index.py (cpu | mps | cuda | auto)
# EE_WIKI_EMBED_DEVICE=cpu

# Optional: LibreOffice binary for legacy .doc ingest (when not on PATH)
# EE_WIKI_LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Optional: external OpenAI-compatible LLM (generation.llm_backend: openai)
# EE_WIKI_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# EE_WIKI_OPENAI_MODEL=Qwen3-30B-A3B-Instruct-2507-MLX-4bit
# EE_WIKI_OPENAI_API_KEY=

# Optional: protect POST /v1/ingest and GET /v1/ingest/jobs/* (LAN admin)
# When unset, ingest stays open (local dev). Send as X-API-Key or Authorization: Bearer.
# EE_WIKI_INGEST_API_KEY=

# API bind address and port: config/default.yaml → api.host / api.port
# (or override via: python scripts/serve.py --host 0.0.0.0 --port 8080)
