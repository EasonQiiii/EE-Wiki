# Copy to .env and adjust for your local deployment.

# Paths (relative to repo root or absolute)
EE_WIKI_DATA_DIR=./data
EE_WIKI_MODELS_DIR=/Users/ml/Documents/Models

# Optional: Tesseract language data for prose PDF OCR (when auto-detect fails)
# EE_WIKI_TESSDATA_DIR=/opt/homebrew/share/tessdata

# Optional: force embedding device for scripts/index.py (cpu | mps | cuda | auto)
# EE_WIKI_EMBED_DEVICE=cpu

# Optional: LibreOffice binary for legacy .doc ingest (when not on PATH)
# EE_WIKI_LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# API
EE_WIKI_HOST=0.0.0.0
EE_WIKI_PORT=8080

# Local LLM (example — set when runtime is chosen)
# EE_WIKI_LLM_BASE_URL=http://127.0.0.1:11434
